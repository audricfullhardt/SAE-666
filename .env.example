# Copier en .env : cp .env.example .env
COMPOSE_PROJECT_NAME=dinoquest

FRONTEND_PORT=5173
BACKEND_PORT=8000
MERCURE_PORT=3000
MYSQL_PORT=3306

MYSQL_DATABASE=dinoquest_dev
MYSQL_USER=dinoquest
MYSQL_PASSWORD=dinoquest
MYSQL_ROOT_PASSWORD=root

APP_ENV=dev
APP_SECRET=dev_change_me_in_prod
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
# Doit correspondre à la passphrase des clés config/jwt
JWT_PASSPHRASE=change_me

MERCURE_JWT_SECRET=!ChangeThisDevMercureJwtSecretKey!
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
MERCURE_CORS_ORIGINS=http://localhost:5173
